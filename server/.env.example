# H Company Models API key (create at https://portal.hcompany.ai).
# When absent, the server falls back to fixture mode automatically.
HAI_API_KEY=

# Gradium API key for /api/voice-token ephemeral token exchange.
# When absent, /api/voice-token returns 503 and voice is disabled.
GRADIUM_API_KEY=

# HTTP port (default 3000).
PORT=3000

# 1 = serve /api/step from server/fixtures/*.json instead of the live model.
HANDYMAN_FIXTURES=

# 1 = after each live /api/step turn, append {request-minus-screenshot, step}
# to server/fixtures/<question-slug>.json for later replay.
HANDYMAN_RECORD=

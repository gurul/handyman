# H Company Models API key (create at https://portal.hcompany.ai).
# Required: /api/step returns 503 without it.
HAI_API_KEY=

# Gradium API key for /api/voice-token ephemeral token exchange.
# When absent, /api/voice-token returns 503 and voice is disabled.
GRADIUM_API_KEY=

# HTTP port (default 3000).
PORT=3000
